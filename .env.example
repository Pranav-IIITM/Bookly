# ─── Bookly Backend Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values for local development.
# In production (Vercel), set these via Dashboard → Project Settings → Env Vars.
# ─────────────────────────────────────────────────────────────────────────────

# Server port (local dev only — Vercel sets its own)
PORT=8080

# Firebase project ID (e.g., booking-platform-943f9)
FIREBASE_PROJECT_ID=

# Option A (recommended for Vercel): Base64-encoded service account JSON
# Generate with: base64 -w0 firebase-service-account.json (Linux/Mac)
#            or: [Convert]::ToBase64String([IO.File]::ReadAllBytes("firebase-service-account.json")) (PowerShell)
FIREBASE_CREDENTIALS_JSON=

# Option B (local dev): Path to service account JSON file
# FIREBASE_CREDENTIALS_PATH=config/firebase-service-account.json
